{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "cleanUrls": true,
  "trailingSlash": false,
  "env": {
    "NEXT_PUBLIC_SOLANA_NETWORK": "devnet",
    "NEXT_PUBLIC_SOLANA_RPC_URL": "https://api.devnet.solana.com",
    "NEXT_PUBLIC_PROGRAM_ID": "3E4wxrT28UqM2ua9n2XnzMMdGoyuR7qZ9VtXQ29XGAgt",
    "NEXT_PUBLIC_USDC_MINT": "4zMMC9srtVu2nuQJHGGMBVsCLqzr6nYHGL9H5LHvpx5h",
    "NEXT_PUBLIC_API_BASE_URL": "https://nusa-harvest-backend.vercel.app"
  },
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
