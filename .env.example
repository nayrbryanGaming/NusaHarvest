# NUSA HARVEST — Environment Configuration (Devnet)
# Copy this to .env.local for development

# Solana Network
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=HrjN1sK3xW2fJ5N2wK8C2AqzRn1fM1VjZkxPjN1sK3xW

# Wallet Connection
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# Backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Legacy alias also supported by frontend runtime:
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Weather APIs
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_key_here

# Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=true
