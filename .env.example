# ── DATABASE ──────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nusa_harvest"

# ── BACKEND SERVER ────────────────
PORT=4000
NODE_ENV=development

# ── BLOCKCHAIN ────────────────────
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed

# ── AUTHENTICATION ────────────────
JWT_SECRET=nusa_harvest_super_secret_key_change_in_production
JWT_EXPIRY=7d

# ── WEATHER API ───────────────────
OPENWEATHER_API_KEY=your_openweather_key_here

# ── FRONTEND ──────────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://nusaharvest.vercel.app

# ── REDIS ─────────────────────────
REDIS_URL=redis://localhost:6379

# ── LOGGING ───────────────────────
LOG_LEVEL=info
